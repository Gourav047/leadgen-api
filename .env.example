# =============================================================================
# LeadBoost API — Environment Variables
# Copy this file to .env and fill in all CHANGE_ME values before starting.
# Variables marked REQUIRED cause the app to exit at startup if missing.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/leadboost

# Test database — used by E2E tests only (not required in production)
DATABASE_URL_TEST=postgresql://postgres:CHANGE_ME@localhost:5432/leadboost_test

# ---------------------------------------------------------------------------
# Authentication (REQUIRED)
# Must be at least 32 characters.
# Generate a secure value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_replace_with_64_char_hex_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PORT=9000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# ---------------------------------------------------------------------------
# Docker Compose
# These are used by docker-compose.yml to build DATABASE_URL for the app
# container. They are NOT read directly by the NestJS app.
# ---------------------------------------------------------------------------
POSTGRES_DB=leadboost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME

# ---------------------------------------------------------------------------
# AI / Vector Store (optional — only needed for AI-powered features)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=leadboost_leads

# ---------------------------------------------------------------------------
# E2E test credentials (test environment only — not used in production)
# ---------------------------------------------------------------------------
EtE_TEST_USERNAME=test@example.com
EtE_TEST_PASSWORD=TestPassword123!
